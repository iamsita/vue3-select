{
  "name": "@matat/vue3-select",
  "version": "0.1.0",
  "description": "A typed, accessible, headless-friendly select for Vue 3. Single, multi, tags, async, grouped — one component, zero surprises.",
  "type": "module",
  "main": "./dist/vue3-select.cjs",
  "module": "./dist/vue3-select.mjs",
  "types": "./dist/src/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/lib/index.d.ts",
      "import": "./dist/vue3-select.mjs",
      "require": "./dist/vue3-select.cjs"
    },
    "./style.css": "./dist/vue3-select.css",
    "./scss": "./src/lib/styles/index.scss",
    "./scss/*": "./src/lib/styles/*"
  },
  "files": [
    "dist",
    "src/lib/styles"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "keywords": [
    "vue",
    "vue3",
    "select",
    "combobox",
    "multiselect",
    "autocomplete",
    "typescript",
    "accessible",
    "headless"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "run-s type-check build:lib",
    "build:lib": "BUILD_TARGET=lib vite build",
    "build:demo": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "peerDependencies": {
    "@floating-ui/vue": "^1.0.0",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@floating-ui/vue": "^1.1.11",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.8",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.60.0",
    "prettier": "3.8.3",
    "sass": "^1.99.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.5",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
