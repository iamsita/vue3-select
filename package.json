{
  "name": "@anilkumarthakur/vue3-select",
  "version": "0.0.1",
  "description": "A typed, accessible, headless-friendly select for Vue 3. Single, multi, tags, async, grouped — one component, zero surprises.",
  "author": "Er. Anil Kumar Thakur <anilkumarthakur60@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/anilkumarthakur60/vue3-select#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anilkumarthakur60/vue3-select.git"
  },
  "bugs": {
    "url": "https://github.com/anilkumarthakur60/vue3-select/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/anilkumarthakur60"
  },
  "type": "module",
  "main": "./dist/vue3-select.cjs",
  "module": "./dist/vue3-select.mjs",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/vue3-select.mjs",
  "jsdelivr": "./dist/vue3-select.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue3-select.mjs",
      "require": "./dist/vue3-select.cjs",
      "default": "./dist/vue3-select.mjs"
    },
    "./nuxt": {
      "types": "./dist/nuxt.d.ts",
      "import": "./dist/nuxt.mjs",
      "require": "./dist/nuxt.cjs",
      "default": "./dist/nuxt.mjs"
    },
    "./style.css": "./dist/vue3-select.css",
    "./scss": "./src/styles/index.scss",
    "./scss/*": "./src/styles/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/styles",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "keywords": [
    "vue",
    "vue3",
    "select",
    "combobox",
    "multiselect",
    "tags",
    "autocomplete",
    "typescript",
    "accessible",
    "a11y",
    "headless",
    "form",
    "dropdown",
    "tree",
    "tree-select",
    "treeselect"
  ],
  "scripts": {
    "dev": "vite --config vite.config.dev.ts",
    "preview": "vite preview --config vite.config.dev.ts --outDir dist-demo",
    "build": "run-s type-check build:lib",
    "build:lib": "vite build",
    "build:demo": "vite build --config vite.config.dev.ts --outDir dist-demo",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "type-check": "vue-tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "format": "prettier --write --experimental-cli \"src/**/*.{ts,tsx,scss}\" \"playground/**/*.{ts,vue}\" \"tests/**/*.ts\"",
    "commitlint": "commitlint --edit",
    "release": "commit-and-tag-version",
    "release:dry": "commit-and-tag-version --dry-run",
    "release:patch": "commit-and-tag-version --release-as patch",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major",
    "prepublishOnly": "run-s test build",
    "prepare": "husky"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.0.0"
  },
  "peerDependencies": {
    "@nuxt/kit": "^3.0.0 || ^4.0.0",
    "nuxt": "^3.0.0 || ^4.0.0",
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    },
    "nuxt": {
      "optional": true
    },
    "vue": {
      "optional": false
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^21.0.1",
    "commit-and-tag-version": "^12.7.1",
    "@nuxt/kit": "^4.4.2",
    "@nuxt/schema": "^4.4.2",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.8",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.60.0",
    "prettier": "3.8.3",
    "sass": "^1.99.0",
    "size-limit": "^12.1.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "size-limit": [
    {
      "name": "ESM (main entry, gzipped)",
      "path": "dist/vue3-select.mjs",
      "import": "*",
      "limit": "12 kB",
      "ignore": [
        "vue",
        "@floating-ui/vue"
      ]
    },
    {
      "name": "CSS (gzipped)",
      "path": "dist/vue3-select.css",
      "limit": "3.5 kB"
    },
    {
      "name": "Tree-shaken: <VSelect> only",
      "path": "dist/vue3-select.mjs",
      "import": "{ VSelect }",
      "limit": "11 kB",
      "ignore": [
        "vue",
        "@floating-ui/vue"
      ]
    },
    {
      "name": "Tree-shaken: useSelection only",
      "path": "dist/vue3-select.mjs",
      "import": "{ useSelection }",
      "limit": "1 kB",
      "ignore": [
        "vue",
        "@floating-ui/vue"
      ]
    }
  ],
  "commit-and-tag-version": {
    "header": "# Changelog\n\nAll notable changes to this project will be documented in this file.\n\nThe format is based on [Keep a Changelog](https://keepachangelog.com/en/1.1.0/),\nand this project adheres to [Semantic Versioning](https://semver.org/spec/v2.0.0.html).\n",
    "types": [
      { "type": "feat", "section": "Features" },
      { "type": "fix", "section": "Bug Fixes" },
      { "type": "perf", "section": "Performance" },
      { "type": "refactor", "section": "Refactors" },
      { "type": "revert", "section": "Reverts" },
      { "type": "docs", "section": "Documentation" },
      { "type": "build", "hidden": true },
      { "type": "ci", "hidden": true },
      { "type": "chore", "hidden": true },
      { "type": "style", "hidden": true },
      { "type": "test", "hidden": true }
    ]
  }
}
